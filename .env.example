# External service credentials. Copy to `.env` and fill in locally.
# `.env` is git-ignored. Never commit real values.

# Anthropic API (extraction workers, agents, live critic)
ANTHROPIC_API_KEY=

# OpenAI API (Whisper transcription of earnings-call audio)
OPENAI_API_KEY=

# Financial Modeling Prep (bid-ask half-spread for backtest cost model;
# transcripts were originally planned here but pivoted to Whisper —
# see docs/decisions/2026-05-23-transcripts-source.md)
FMP_API_KEY=

# Voyage AI embeddings (primary; falls back to local BGE if absent)
VOYAGE_API_KEY=

# Langfuse self-hosted (Docker compose — see Issue #2)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000

# OpenTelemetry export to Langfuse (OTLP)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:3000/api/public/otel

# MLflow local file backend (Issue #3)
MLFLOW_TRACKING_URI=file:./mlruns

# SEC EDGAR User-Agent (required by SEC; see Issue #5)
SEC_USER_AGENT="auto-research <your-name> <your-email>"

# Embedding backend selection — required, no default fallback in code.
# voyage (cloud) | bge (cross-platform in-process) | qwen3-mlx (Apple-Silicon-only).
# qwen3-mlx is the local-Mac dev default per Issue #65; production may override
# to voyage per ADR D1.
EMBEDDING_BACKEND=qwen3-mlx

# Optional MLX Qwen3-Embedding variant — only honored when
# EMBEDDING_BACKEND=qwen3-mlx. Adapter kwarg today; env-var wiring is a
# follow-up if the dev/deploy split warrants it.
# MLX_QWEN3_MODEL=Qwen3-Embedding-0.6B
