# External service credentials. Copy to `.env` and fill in locally.
# `.env` is git-ignored. Never commit real values.

# Anthropic API (extraction workers, agents, live critic)
ANTHROPIC_API_KEY=

# Financial Modeling Prep (earnings transcripts + bid-ask spreads)
FMP_API_KEY=

# Voyage AI embeddings (primary; falls back to local BGE if absent)
VOYAGE_API_KEY=

# Langfuse self-hosted (Docker compose — see Issue #2)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000

# OpenTelemetry export to Langfuse (OTLP)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:3000/api/public/otel

# MLflow local file backend (Issue #3)
MLFLOW_TRACKING_URI=file:./mlruns

# SEC EDGAR User-Agent (required by SEC; see Issue #5)
SEC_USER_AGENT="auto-research <your-name> <your-email>"
