# Per-issue worktrees (Option C layout per docs/AI_WORKFLOW.md §1)
.worktree/

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
build/
dist/

# uv / virtualenv
.venv/

# Environments — never commit real secrets (also enforced by .claude/settings.json)
.env
.env.local
.env.*.local

# Tooling caches
.mypy_cache/
.ruff_cache/
.pytest_cache/

# Coverage
.coverage
.coverage.*
htmlcov/
coverage.xml

# OS
.DS_Store

# Editors
.idea/
.vscode/
*.swp

# Project data — audit trail; never committed (also enforced by .claude/settings.json deny)
data/raw/
data/extracted/
data/quarantine/
data/manifest.parquet

# MLflow local backend
mlruns/
mlartifacts/

# Langfuse local Docker volumes
.langfuse/
postgres-data/

# LanceDB stores (per-doc + memos)
*.lance/

# DeepEval cache
.deepeval/

# Feast offline store (Parquet) + registry SQLite — directory itself is
# tracked via a .gitkeep so `feast apply` has somewhere to write the registry.
feast_repo/data/*
!feast_repo/data/.gitkeep

# Personal learning / self-study notes — kept local, never pushed.
docs/learning/

# Extraction cache (content-hash idempotent — bumping *_PROMPT_VERSION or
# SCHEMA_VERSION naturally invalidates entries; see INV-6).
data/cache/

# Promotion-gate decisions log (scripts/promote_prompt.py)
eval/promotions/

# Gold-set labeling scratch (intermediate; gold JSONL is the committed artifact)
eval/gold_sets/_worksheets/
